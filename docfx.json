{
  "$schema": "https://raw.githubusercontent.com/dotnet/docfx/main/schemas/docfx.schema.json",
  "metadata": [
    {
      "src": [
        {
          "files": [
            "ext/ImageSharp/src/**.csproj"
          ]
        }
      ],
      "output": "api/ImageSharp",
      "disableGitFeatures": false,
      "disableDefaultFilter": false,
      "properties": {
        
      }
    },
    {
      "src": [
        {
          "files": [
            "ext/ImageSharp.Drawing/src/**.csproj"
          ]
        }
      ],
      "output": "api/ImageSharp.Drawing",
      "disableGitFeatures": false,
      "disableDefaultFilter": false,
      "properties": {
        
      }
    },
    {
      "src": [
        {
          "files": [
            "ext/Fonts/src/SixLabors.Fonts/**.csproj"
          ]
        }
      ],
      "output": "api/Fonts",
      "disableGitFeatures": false,
      "disableDefaultFilter": false,
      "properties": {

      }
    },
    {
      "src": [
        {
          "files": [
            "ext/ImageSharp.Web/src/ImageSharp.Web/**.csproj"
          ]
        }
      ],
      "output": "api/ImageSharp.Web",
      "disableGitFeatures": false,
      "disableDefaultFilter": false,
      "properties": {
        
      }
    },
    {
      "src": [
        {
          "files": [
            "ext/ImageSharp.Web/src/ImageSharp.Web.Providers.Azure/**.csproj"
          ]
        }
      ],
      "output": "api/ImageSharp.Web.Providers.Azure",
      "disableGitFeatures": false,
      "disableDefaultFilter": false,
      "properties": {
        
      }
    },
    {
      "src": [
        {
          "files": [
            "ext/ImageSharp.Web/src/ImageSharp.Web.Providers.AWS/**.csproj"
          ]
        }
      ],
      "output": "api/ImageSharp.Web.Providers.AWS",
      "disableGitFeatures": false,
      "disableDefaultFilter": false,
      "properties": {
        
      }
    },
        {
      "src": [
        {
          "files": [
            "ext/PolygonClipper/src/PolygonClipper/**.csproj"
          ]
        }
      ],
      "output": "api/PolygonClipper",
      "disableGitFeatures": false,
      "disableDefaultFilter": false,
      "properties": {
        
      }
    }
  ],
  "build": {
    "xref": [
      "xrefmap.yml"
    ],
    "content": [
      {
        "files": [
          "**/*.{md,yml}"
        ],
        "exclude": [
          "README.md",
          "_site/**",
          "**/codecov.yml"
        ]
      }
    ],
    "resource": [
      {
        "files": [
          "images/**",
          "favicon.ico",
          "CNAME"
        ]
      }
    ],
    "output": "_site",
    "template": [
      "default",
      "modern",
      "templates/modern"
    ],
    "globalMetadata": {
      "_gitContribute": {
        "branch": "main"
      },
      "_enableSearch": true,
      "pdf": true,
       "_appLogoPath": "public/logo.svg",
       "_appFaviconPath": "public/favicon.ico"
    }
  }
}